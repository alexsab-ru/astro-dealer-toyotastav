---
import Layout from '@/layouts/Layout.astro';
import Form from '@/components/FeedbackForm/Form.astro';
import settings from '@/data/settings.json';
import PageH1 from '@/components/PageH1/Index.astro';
const { brand, legal_city_where } = settings;
---

<Layout title={`Оценка стоимости автомобиля в ${legal_city_where} | ${brand}`} description={`Узнайте точную стоимость вашего автомобиля с помощью оценки от официального дилера ${brand} в ${legal_city_where}.`}>
	<div class="container py-10 space-y-10">
		<div>
			<PageH1 h1={`Оцените ваш автомобиль в официальном дилерском центре ${brand} в ${legal_city_where}`} classes="text-3xl sm:text-4xl font-bold text-center" />
			<p class="text-center mt-1 text-gray-500">Бесплатная оценка и диагностика специалистом</p>
		</div>
		<Form dataFormName="Оценка стоимости автомобиля" labelBtn="Записаться на оценку" />
	</div>
</Layout>