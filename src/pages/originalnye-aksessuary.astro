<Layout title={`Оригинальные аксессуары для автомобилей ${brand} – Официальный дилерский центр ${brand} в ${legal_city_where}`} description={`Широкий выбор оригинальных аксессуаров для автомобилей ${brand}. Улучшите комфорт, стиль и функциональность вашего авто с сертифицированными аксессуарами от официального дилера ${brand} в ${legal_city_where}.`}>
	<div class="container py-10 space-y-10 xl:space-y-14 content">
		<PageH1 h1={`Оригинальные аксессуары ${brand}`} classes="text-3xl sm:text-4xl font-bold text-center" />
		<div class="overflow-auto sm:overflow-visible min-w-full">
			<table>
				<thead class="sm:sticky sm:-top-[1px] lg:top-[49px] !bg-accent-500 text-white">
					<tr>
						<th>#</th>
						<th>Фото</th>
						<th>Наименование</th>
						<th>№ по каталогу</th>
						<th>Цена единицы</th>
					</tr>
				</thead>
				<tbody>
					{accessories.map((accessory, idx) => (
						<tr>
							<td>{idx+1}</td>
							<td class="align-middle">
								<a 
									href={accessory.image} 
									class="text-center glightbox !no-underline block hover:opacity-90" 
									data-title={`${accessory.name}`} 
									data-description={`
										Арт. ${accessory.article}</br>
										<strong>${currencyFormat(accessory.price)}</strond>
									`} data-gallery={`gallery-accessories`}>
									<img 
										src={accessory.image} 
										class="min-w-[50px] sm:min-w-0 max-w-[250px]" 
										width={250} 
										height={177} 
										alt={accessory.name} 
										loading="lazy" 
									/>
								</a>
							</td>
							<td>
                <a class="popup-link" href="#common-modal" data-title={`Узнать подробнее про ${accessory.name}`} data-form_name={`Узнать подробнее про ${accessory.name}`}>{accessory.name}</a>
              </td>
							<td>{accessory.article}</td>
							<td class="font-semibold">{currencyFormat(accessory.price)}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</div>

</Layout>