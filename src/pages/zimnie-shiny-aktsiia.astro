---
import Layout from '@/layouts/Layout.astro';
import settings from '@/data/settings.json';
import PageH1 from '@/components/PageH1/Index.astro';

import { currencyFormat } from '@/js/utils/numbers.format';

const { brand, legal_city_where } = settings;
const accessories = [
  {
    "name": "Michelin X-ICE 3",
    "size": "205/55 R16",
    "price": 5968.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/1.webp"
  },
  {
    "name": "NOKIAN HAKKAPELIITTA R2",
    "size": "215/60 R17",
    "price": 8738.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/2.webp"
  },
  {
    "name": "Kumho KW-31",
    "size": "215/60 R17",
    "price": 9400.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/3.webp"
  },
  {
    "name": "Michelin X-ICE 3",
    "size": "215/60 R17",
    "price": 9015.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/4.webp"
  },
  {
    "name": "Michelin X-ICE 3",
    "size": "225/60 R18",
    "price": 11742.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/5.webp"
  },
  {
    "name": "Michelin X-ICE 2",
    "size": "225/60 R17",
    "price": 9730.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/6.webp"
  },
  {
    "name": "Michelin X-ICE 3",
    "size": "235/45 R18",
    "price": 13321.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/7.webp"
  },
  {
    "name": "Michelin X-ICE 2",
    "size": "265/60 R18",
    "price": 11800.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/8.webp"
  },
  {
    "name": "Michelin X-ICE 2",
    "size": "265/65 R17",
    "price": 11062.0,
    "image": "https://cdn.alexsab.ru/specials/toyota/zimnie-shiny-aktsiia/9.webp"
  }
];
---

<Layout title={`Акции на зимние шины для ${brand} – Выгодные предложения`} description={`Специальные акции на зимние шины для автомобилей ${brand}. Получите качественные зимние шины по выгодным ценам от официального дилера ${brand} в ${legal_city_where}. Надежность и безопасность на зимних дорогах.`}>
	<div class="container py-10 space-y-10 xl:space-y-14 content">
		<PageH1 h1={`Зимние шины - Акция!`} classes="text-3xl sm:text-4xl font-bold text-center" />
		<div class="overflow-auto sm:overflow-visible min-w-full">
			<table>
				<thead class="sm:sticky sm:-top-[1px] lg:top-[49px] !bg-accent-500 text-white">
					<tr>
						<th>#</th>
						<th>Фото</th>
						<th>Наименование</th>
						<th>Размер</th>
						<th>Стоимость</th>
					</tr>
				</thead>
				<tbody>
					{accessories.map((accessory, idx) => (
						<tr>
							<td>{idx+1}</td>
							<td class="align-middle">
								<a 
									href={accessory.image} 
									class="text-center glightbox !no-underline" 
									data-title={`${accessory.name}`} 
									data-description={`
										Размер: ${accessory.size}</br>
										<strong>${currencyFormat(accessory.price)}</strond>
									`} data-gallery={`gallery-accessories`}>
									<img 
										src={accessory.image} 
										class="min-w-[50px] sm:min-w-0 max-w-[250px]" 
										width={250} 
										height={177} 
										alt={accessory.name} 
										loading="lazy" 
									/>
								</a>
							</td>
							<td>{accessory.name}</td>
							<td>{accessory.size}</td>
							<td class="font-semibold">{currencyFormat(accessory.price)}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</div>

</Layout>